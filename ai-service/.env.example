# AI orchestration API
AI_API_DEBUG=true
AI_API_LOG_LEVEL=INFO
AI_API_DATABASE_URL=sqlite+aiosqlite:///./data/ai_service.db
AI_API_STORAGE_LOCAL_PATH=./data/outputs
AI_API_CORS_ORIGINS=http://localhost:3000
AI_API_API_KEY_SECRET=replace-with-a-random-secret
AI_API_JWT_SECRET_KEY=replace-with-a-random-secret
AI_API_GEMINI_API_KEY=
AI_API_GENAI_PREFER_API=true
AI_API_GENAI_USE_IMAGEN=false
AI_API_GENAI_SKIP_WAV2LIP=true
AI_API_LIVESTREAM_ENABLE_WAV2LIP=false
AI_API_WAV2LIP_DIR=/content/Wav2Lip
AI_API_WAV2LIP_CHECKPOINT=/content/Wav2Lip/checkpoints/Wav2Lip-SD-GAN.pt

# RAG service
RAG_OPENAI_API_KEY=
RAG_OPENAI_MODEL=gpt-4o-mini
RAG_KNOWLEDGE_BASE_PATH=services/rag_service/resources/knowledge_base.json

# Sales agent
GOOGLE_API_KEY=
GROQ_API_KEY=
SALES_AGENT_PRIMARY_MODEL=gemini-2.0-flash
SALES_AGENT_FALLBACK_MODEL=groq/llama-3.3-70b-versatile
