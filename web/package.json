{
  "name": "sea-hackathon-2026",
  "private": true,
  "scripts": {
    "dev": "dotenv -e .env -- bash -c 'if [ \"$WEB_VERSION\" = \"v1\" ]; then turbo run dev --filter=!web-v2; else turbo run dev --filter=!@sea/web; fi'",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "turbo run db:push",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dotenv-cli": "^8.0.0",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2"
  },
  "packageManager": "pnpm@9.15.0"
}
