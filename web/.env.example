# ─── Local development (copy to .env) ────────────────────────────────────────
# Infrastructure runs via: pnpm infra:up (docker compose up -d)
# Apps run via:            pnpm dev      (turbo run dev)

DATABASE_URL=postgres://postgres:postgres@localhost:54320/sea_hackathon
RABBITMQ_URL=amqp://guest:guest@localhost:56720
AWS_ENDPOINT_URL=http://localhost:45760
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=ap-southeast-1
S3_BUCKET=livestream-videos
NODE_ENV=development

# Auth
JWT_SECRET=change-this-to-a-strong-random-secret
FRONTEND_URL=http://localhost:43100

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:43101/api/auth/google/callback

# API
API_URL=http://localhost:43101

# Streamer
STREAMER_PORT=43102
RTMP_PORT=19450

# Web version: v1 (Next.js) or v2 (Vite/React) — controls which frontend pnpm dev runs
WEB_VERSION=v2
WEB_V2_PORT=
